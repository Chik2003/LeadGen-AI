        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "email",
              "value": "={{ $json.email }}"
            },
            {
              "name": "api_key",
              "value": "YOUR_HUNTER_IO_API_KEY"
            }
          ]
        },
        "options": {
