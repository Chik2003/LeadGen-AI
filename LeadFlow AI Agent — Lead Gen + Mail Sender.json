      "id": "42d5d988-13ec-49e1-9ca0-5da60d8a8401",
      "name": "Verify Email (Hunter.io)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        880,
        112
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst verification = item.data || {};\nconst isVerified = verification.status === 'valid';\nreturn [{\n  json: {\n    ...item,\n    email_verified: isVerified,\n    email_status: verification.status || 'unknown',\n    smtp_check: verification.smtp_check || false,\n    disposable: verification.disposable || false,\n    status: isVerified ? 'verified' : 'unverified'\n  }\n}];"
      },
      "id": "b476516a-ff38-40f9-9b4f-a463c795db72",
      "name": "Merge Verification Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1104,
        112
      ]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.email_verified }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "278fb43b-9ddd-45b7-b57f-ce26489d77b8",
      "name": "Route: Verified Only",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [
        1328,
        112
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nlet emailContent = {};\ntry {\n  const raw = item.message?.content || item.content || '{}';\n  const cleaned = raw.replace(/```json/g, '').replace(/```/g, '').trim();\n  emailContent = JSON.parse(cleaned);\n} catch(e) {\n  emailContent = { subject: 'Quick question for you', body: 'Hi ' + item.full_name + ',\\n\\nWould love to connect.' };\n}\nreturn [{ json: { ...item, email_subject: emailContent.subject, email_body: emailContent.body } }];"
      },
