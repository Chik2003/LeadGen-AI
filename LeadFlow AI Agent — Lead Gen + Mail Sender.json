    {
      "parameters": {
        "agent": "conversationalAgent",
        "promptType": "define",
        "text": "=You are a lead qualification AI. Given raw scraped data, extract structured lead information and score each lead.\n\nRaw data: {{ JSON.stringify($json) }}\n\nFor each lead, extract:\n- full_name (string)\n- email (string)\n- company (string)\n- role (string)\n- linkedin_url (string or null)\n- website (string or null)\n- industry (string)\n- location (string)\n- qualification_score (0-100, based on: has email=+40, has LinkedIn=+20, clear role=+20, matches target industry=+20)\n- pain_points (string, 1-2 sentences about likely challenges)\n- personalization_hook (string, 1 sentence for email opening)\n\nReturn ONLY a valid JSON array of lead objects. No markdown, no explanation.",
        "options": {
          "systemMessage": "You are a precise lead extraction AI. Always return valid JSON arrays only.",
          "maxIterations": 3
        }
      },
      "id": "5ac40fd4-579d-4198-a8e1-5f7585c35136",
      "name": "AI Agent — Extract & Score Leads",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        224,
        112
      ]
    },
    {
      "parameters": {
        "jsCode": "const rawOutput = $input.first().json.output || $input.first().json.text || '[]';\nlet leads = [];\ntry {\n  const cleaned = rawOutput.replace(/```json/g, '').replace(/```/g, '').trim();\n  leads = JSON.parse(cleaned);\n} catch(e) {\n  const match = rawOutput.match(/\\[.*\\]/s);\n  if (match) leads = JSON.parse(match[0]);\n}\nreturn leads.map(lead => ({ json: { ...lead, status: 'scraped', created_at: new Date().toISOString() } }));"
      },
      "id": "3d809374-4af1-4f17-ace6-6f00a4aacc10",
      "name": "Parse AI Lead JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        112
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.qualification_score }}",
              "rightValue": 60,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            },
            {
              "leftValue": "={{ $json.email }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "5b5906a6-3b1a-45cd-a7e3-eaeb60b4028c",
      "name": "Filter High-Score Leads",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [
        672,
